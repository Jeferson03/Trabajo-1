  - kind: 1
    value: "#### Ahora carguemos las tablas con 100.000 facturas y 1.000.000 de
      detalles (10 detalles por factura)"
    languageId: markdown
  - kind: 2
    value: "TRUNCATE TABLE detalle;\r

      TRUNCATE TABLE factura;\r

      \r

      DECLARE\r

      \    v_cantidad_facturas NUMBER(8) := 100000;\r

      \    v_cantidad_detalles NUMBER(10) := 10;\r

      \r

      \r

